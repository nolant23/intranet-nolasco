// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   // "ADMIN", "UFFICIO", "TECNICO"
  attivo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  manutenzioni       Manutenzione[]
  interventi         Intervento[]
  presenze           Presenza[]
  verificheBiennali  VerificaBiennale[]
  presenzeCantiere   PresenzaCantiere[]
  pushSubscriptions  PushSubscription[]
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String
  p256dh    String   // chiave pubblica client
  auth      String   // segreto auth
  userAgent String?  // opzionale, per riconoscere il dispositivo
  createdAt DateTime @default(now())

  @@unique([userId, endpoint])
  @@index([userId])
}

model NotificationSetting {
  id                 String   @id @default(uuid())
  eventKey           String   @unique // es. "manutenzione.created", "intervento.created"
  label              String   // etichetta per l'UI (es. "Nuova manutenzione")
  sendToTecnico      Boolean  @default(true)
  sendToAdminUfficio Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Cliente {
  id            String   @id @default(uuid())
  denominazione String
  indirizzo     String
  comune        String
  cap           String
  provincia     String
  email         String?
  pec           String?
  codiceSdi     String?
  cellulare     String?
  glideId       String?
  ficId         String?  @unique
  tipologia     String   // "Persona Fisica", "Azienda", "Condominio", "PA"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // --- Fatture in Cloud (anagrafica cliente) ---
  ficCode                    String?
  ficType                    String? // business/person/company/etc.
  ficFirstName               String?
  ficLastName                String?
  ficContactPerson           String?
  ficVatNumber               String?
  ficTaxCode                 String?
  ficAddressStreet           String?
  ficAddressPostalCode       String?
  ficAddressCity             String?
  ficAddressProvince         String?
  ficAddressExtra            String?
  ficCountry                 String?
  ficCountryIso              String?
  ficCertifiedEmail          String?
  ficPhone                   String?
  ficFax                     String?
  ficNotes                   String?
  ficDefaultVatJson          String? // JSON string
  ficDefaultPaymentTerms     Int?
  ficDefaultPaymentTermsType String?
  ficDefaultPaymentMethodJson String? // JSON string
  ficBankIban                String?
  ficBankName                String?
  ficBankSwift               String?
  ficShippingAddressJson     String? // JSON string
  ficEInvoice                Boolean?
  ficEiCode                  String?
  ficDiscountCustom          Float?
  ficCreatedAt               DateTime?
  ficUpdatedAt               DateTime?

  impianti      Impianto[]
  fatture       Fattura[]
  noteCreditoFiC NotaCredito[]
  bookingClienti BookingCliente[]
}

model Amministratore {
  id            String   @id @default(uuid())
  denominazione String
  indirizzo     String
  comune        String
  cap           String
  provincia     String
  email         String?
  pec           String?
  telefono      String?
  cellulare     String?
  codiceSdi     String?
  note          String?
  glideIdAmm    String?  @unique
  glidePrintTrigger Boolean?
  glideEcUrl    String?
  glidePdfGlide String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  impianti      Impianto[]
}

model Impianto {
  id               String   @id @default(uuid())
  numeroImpianto   String?
  glideRowId       String?  @unique
  glideImpianto    String?
  indirizzo        String
  comune           String
  cap              String?
  provincia        String?
  enteNotificato   String?
  tipologia        String?
  modello          String?
  numeroFabbrica   String?
  matricola        String?
  portata          Float?
  fermate          Int?
  servizi          Int?
  costruttore      String?
  installatore     String?
  naturaVano       String?
  produttoreStruttura String?
  testata          Float?
  corsa            Float?
  fossa            Float?
  azionamento      String?
  alimentazione    String?
  posizioneQuadro  String?
  funi             String?
  guideCabina      String?
  guideContrappeso String?

  glideAmministratoreIdAmmImp    String?
  glideClienteIdClienteImp       String?
  glideClienteIdClienteFic       String?
  glideClienteIdClienteFicNumber Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  clienteId        String?
  cliente          Cliente? @relation(fields: [clienteId], references: [id])

  amministratoreId String?
  amministratore   Amministratore? @relation(fields: [amministratoreId], references: [id])

  contratti          Contratto[]
  manutenzioni       Manutenzione[]
  interventi         Intervento[]
  verificheBiennali   VerificaBiennale[]

  @@index([numeroImpianto])
  @@index([clienteId])
  @@index([amministratoreId])
}

model Contratto {
  id                    String   @id @default(uuid())
  numero                String?  @unique
  tipologia             String?
  dataEmissione         DateTime @default(now())
  dataContratto         DateTime?
  scadenzaContratto     DateTime?
  statoContratto        String?  // "ATTIVO", "SCADUTO", "DISDETTO"
  durataAnni            Int?
  numeroVisiteAnnue     Int?
  canoneManutenzione    Float?   // Euro, 2 decimals
  periodicitaFatturazione String? // "Mensile", "Trimestrale", "Semestrale", "Annuale"
  dataInizioFatturazione  DateTime?
  gratuito              Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  impiantoId            String?
  impianto              Impianto? @relation(fields: [impiantoId], references: [id], onDelete: SetNull)

  servizi               ServizioContratto[]

  @@index([statoContratto])
  @@index([impiantoId])
  @@index([dataInizioFatturazione])
  @@index([gratuito])
}

model ServizioContratto {
  id          String   @id @default(uuid())
  nome        String
  importo     Float?   @default(0)
  ra          Boolean  @default(false)
  iva         String?

  contrattoId String
  contratto   Contratto @relation(fields: [contrattoId], references: [id], onDelete: Cascade)

  @@index([contrattoId])
}

model Manutenzione {
  id                String   @id @default(uuid())
  glideId           String?  @unique // id manutenzione dal CSV Glide, evita duplicati in import
  dataManutenzione  DateTime @default(now())
  oraEsecuzione     String?

  tecnicoId         String
  tecnico           User     @relation(fields: [tecnicoId], references: [id])

  impiantoId        String
  impianto          Impianto @relation(fields: [impiantoId], references: [id])

  clienteFirmatario String
  firmaTecnico      String?  // Base64
  firmaCliente      String?  // Base64
  note              String?
  rapportinoPdf     String?  // URL del PDF generato

  // Controlli semestrali
  effettuaSemestrale                 Boolean @default(false)
  efficienzaParacadute               Boolean?
  efficienzaLimitatoreVelocita       Boolean?
  efficienzaDispositiviSicurezza     Boolean?
  condizioneFuni                     String?
  condizioniAttacchiFuni             String?
  condizioneIsolamentoImpianto       String?
  efficienzaCollegamentiTerra        Boolean?
  osservazioniSemestrale             String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([impiantoId, dataManutenzione])
  @@index([tecnicoId, dataManutenzione])
  @@index([dataManutenzione])
}

model Intervento {
  id                String   @id @default(uuid())
  dataIntervento    DateTime @default(now())
  oraInizio         String
  oraFine           String
  
  tecnicoId         String
  tecnico           User     @relation(fields: [tecnicoId], references: [id])
  
  impiantoId        String
  impianto          Impianto @relation(fields: [impiantoId], references: [id])
  
  descrizione       String?
  partiSostituite   String?
  materialeOrdinare String?
  foto              String?  // JSON string per salvare array di URL/base64
  
  clienteFirmatario String
  firmaTecnico      String?  // Base64
  firmaCliente      String?  // Base64
  rapportinoPdf     String?  // URL del PDF generato
  numeroRapportino  String?  // Formato 000/YYYY
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([impiantoId, dataIntervento])
  @@index([tecnicoId, dataIntervento])
  @@index([dataIntervento])
}

model VerificaBiennale {
  id                  String   @id @default(uuid())
  dataVerifica         DateTime
  firmaCliente         String?  @db.Text // Base64 (data URL)
  clienteFirmatario    String?
  enteNotificato       String?
  ingegnere            String?
  verbaleUrl           String?
  prescrizioni         String?  @db.Text

  impiantoId           String?
  impianto             Impianto? @relation(fields: [impiantoId], references: [id], onDelete: SetNull)

  tecnicoId            String?
  tecnico              User?    @relation(fields: [tecnicoId], references: [id], onDelete: SetNull)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([impiantoId])
  @@index([tecnicoId])
  @@index([dataVerifica])
}

model RolePermission {
  id          String   @id @default(uuid())
  role        String   @unique // "ADMIN", "UFFICIO", "TECNICO"
  permissions String   // JSON string
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Presenza {
  id               String   @id @default(uuid())
  data             DateTime
  
  tecnicoId        String
  tecnico          User     @relation(fields: [tecnicoId], references: [id])
  
  oreOrdinario     Float?   @default(0)
  orePermesso      Float?   @default(0)
  oreMalattia      Float?   @default(0)
  oreStraordinario Float?   @default(0)
  oreFestivo       Float?   @default(0)
  oreFerie         Float?   @default(0)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([data, tecnicoId])
}

model Fattura {
  id            String   @id @default(uuid())
  ficId         String   @unique
  tipoDocumento String?
  numero        String
  data          DateTime
  dataScadenza  DateTime?
  
  clienteNome          String
  clientePartitaIva    String?
  clienteCodiceFiscale String?
  clienteIndirizzo     String?
  clienteFicId         String?
  clienteId            String?
  cliente              Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  
  oggetto       String?
  note          String?
  
  importoNetto  Float
  importoIva    Float?   @default(0)
  importoRA     Float?   @default(0) // RA (ritenuta d'acconto) da amount_withholding_tax
  importoTotale Float
  
  stato         String
  metodoPagamento         String?
  statoFatturaElettronica String?
  statoEmail              String?  // "sent" quando inviata via email da app
  
  articoliJson  String?  // JSON string
  pagamentiJson String?  // JSON string
  
  urlDocumento  String?
  
  noteCredito   NotaCredito[]
  condizioniPagamento CondizionePagamento[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([data])
  @@index([numero])
  @@index([clienteId])
  @@index([stato])
  @@index([statoFatturaElettronica])
  @@index([statoEmail])
}

model NotaCredito {
  id            String   @id @default(uuid())
  ficId         String   @unique
  numero        String
  data          DateTime
  
  clienteNome          String
  clientePartitaIva    String?
  clienteCodiceFiscale String?
  
  oggetto       String?
  note          String?
  
  importoNetto  Float
  importoIva    Float?   @default(0)
  importoTotale Float
  
  urlDocumento  String?
  
  fatturaId     String?
  fattura       Fattura? @relation(fields: [fatturaId], references: [id], onDelete: SetNull)
  clienteFicId  String?
  clienteId     String?
  cliente       Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([data])
  @@index([numero])
  @@index([fatturaId])
  @@index([clienteId])
}

model Booking {
  id                  String   @id @default(uuid())
  codiceImpianto      String   // es. A21K0100
  indirizzoImpianto   String?
  comuneImpianto      String?
  provinciaImpianto   String?
  capImpianto         String?
  dataContratto       DateTime?
  tipologiaImpianto   String?  // Piattaforma Elevatrice, Ascensore, Montascale, etc.
  modelloImpianto     String?
  statoMateriali      String?
  montaggio           Float?   // importo
  contrattoFirmatoUrl String?  @db.Text
  disegnoDefinitivoUrl String? @db.Text
  inizioMontaggio     DateTime?
  fineMontaggio       DateTime?
  statoMontaggio      String?
  enteNotificato      String?
  nIdentificazioneEnte String?
  nAttestato          String?
  dm37Url             String?  @db.Text
  progettazione       Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  clienti             BookingCliente[]
  condizioniPagamento CondizionePagamento[]
  presenzeCantiere   PresenzaCantiere[]

  @@index([codiceImpianto])
  @@index([dataContratto])
  @@index([statoMontaggio])
}

model PresenzaCantiere {
  id           String   @id @default(uuid())
  data         DateTime
  oreCantiere  Float
  descrizione  String?  @db.Text
  bookingId    String
  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  tecnicoId    String
  tecnico      User     @relation(fields: [tecnicoId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([bookingId])
  @@index([tecnicoId])
  @@index([data])
}

model CondizionePagamento {
  id            String   @id @default(uuid())
  condizione    String   // es. "30% ALL'ORDINE"
  importo       Float    // importo in euro
  importoPagato Float   @default(0) // importo già pagato dal cliente
  ordine        Int      @default(0) // ordine visualizzazione

  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  fatturaFicId String? // FiC id per collegamento a Fattura (Fattura.ficId)
  fattura     Fattura? @relation(fields: [fatturaFicId], references: [ficId], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([bookingId])
  @@index([fatturaFicId])
}

model BookingCliente {
  id         String   @id @default(uuid())
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  clienteId  String
  cliente    Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([bookingId, clienteId])
  @@index([bookingId])
  @@index([clienteId])
}

